generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TradeType {
  EQUITY
  OPTIONS
  FUTURES
  FOREX
  CRYPTO
  COMMODITY
  INDEX
}

enum Direction {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  REVIEWED
}

model Trade {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  symbol          String
  tradeType       TradeType   @map("trade_type")
  direction       Direction
  status          TradeStatus @default(OPEN)
  entryPrice      Decimal     @map("entry_price") @db.Decimal(12, 4)
  exitPrice       Decimal?    @map("exit_price") @db.Decimal(12, 4)
  quantity        Decimal     @db.Decimal(12, 4)
  stopLoss        Decimal?    @map("stop_loss") @db.Decimal(12, 4)
  takeProfit      Decimal?    @map("take_profit") @db.Decimal(12, 4)
  pnl             Decimal?    @db.Decimal(12, 4)
  fees            Decimal     @default(0) @db.Decimal(12, 4)
  riskRewardRatio Decimal?    @map("risk_reward_ratio") @db.Decimal(6, 2)
  strategyId      String?     @map("strategy_id")
  notes           String?
  tags            String[]    @default([])
  openedAt        DateTime    @map("opened_at")
  closedAt        DateTime?   @map("closed_at")
  reviewedAt      DateTime?   @map("reviewed_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  images          TradeImage[]
  strategy        Strategy?   @relation("TradeStrategy", fields: [strategyId], references: [id], onDelete: SetNull)
  mistakes        Mistake[]   @relation("TradeMistakes")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, openedAt(sort: Desc)])
  @@index([userId, symbol])
  @@map("trades")
}

model TradeImage {
  id           String   @id @default(uuid())
  tradeId      String   @map("trade_id")
  filePath     String   @map("file_path")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  createdAt    DateTime @default(now()) @map("created_at")

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_images")
}

enum MistakeCategory {
  FOMO
  OVERTRADING
  NO_STOP_LOSS
  MOVED_STOP_LOSS
  EARLY_EXIT
  LATE_ENTRY
  REVENGE_TRADE
  POSITION_SIZE
  IGNORED_RULES
  EMOTIONAL
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Strategy {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  name          String
  description   String?
  rules         String[] @default([])
  tags          String[] @default([])
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  trades        Trade[]  @relation("TradeStrategy")
  mistakes      Mistake[]

  @@unique([userId, name])
  @@index([userId])
  @@map("strategies")
}

model Mistake {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  tradeId     String?         @map("trade_id")
  strategyId  String?         @map("strategy_id")
  category    MistakeCategory
  description String
  lesson      String?
  severity    Severity        @default(MEDIUM)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  trade       Trade?          @relation("TradeMistakes", fields: [tradeId], references: [id], onDelete: SetNull)
  strategy    Strategy?       @relation(fields: [strategyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, category])
  @@index([tradeId])
  @@map("mistakes")
}
